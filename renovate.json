{
  "enabled": true,
  "forkProcessing": "enabled",
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Racer159/uds-common//config/renovate4.json5",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers",
    "group:all",
    "replacements:all",
    "workarounds:all"
  ],
  "packageRules": [
    {
      "groupName": "Support Dependencies",
      "labels": [
        "support-deps"
      ],
      "commitMessageTopic": "support-deps",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "groupName": "Package Dependencies",
      "labels": [
        "package-deps"
      ],
      "commitMessageTopic": "package-deps",
      "matchPackageNames": ["!/^mcr\\.microsoft\\.com\\/playwright$/"],
      "matchDatasources": [
        "docker",
        "helm",
        "git-tags"
      ]
    }
  ]
}
